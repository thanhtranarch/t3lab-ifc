PORT=3000
FRONTEND_URL=http://localhost:5173

# Firebase Web API key — dùng để xác thực ID token gửi từ client (REST
# accounts:lookup, không cần Admin SDK/service-account). Key này vốn công
# khai theo thiết kế Firebase (đã có sẵn trong bundle frontend), nhưng vẫn
# có thể override nếu đổi project Firebase.
# FIREBASE_API_KEY=AIzaSyCrqJiIxlahcHZuwa7xS7KMX8Z5c6Ky3Oo

# Giới hạn tần suất gọi AI theo uid (mặc định 20 yêu cầu / 10 phút)
# AI_RATE_LIMIT_MAX=20
# AI_RATE_LIMIT_WINDOW_MS=600000

# ── AI providers (đặt key cho provider muốn thử nghiệm) ──
# Anthropic (Claude) — provider mặc định
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI & mọi endpoint tương thích (OpenRouter, Groq, LM Studio, Ollama…)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_DEFAULT_MODEL=gpt-4o-mini

# DeepSeek (tương thích OpenAI) — cũng là provider cho serverless /api/ai/chat trên Vercel
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Gemini
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_DEFAULT_MODEL=gemini-2.0-flash
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
