{
  // Type-checking config for the standalone build (root). The src/app/*.ts
  // feature files share one global script scope (see src/app/globals.d.ts);
  // build.ts/scripts are Node ESM modules. Settings are intentionally loose
  // to match the legacy, lightly-typed codebase — the deployable build is
  // produced by esbuild (build.ts), not by tsc.
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true
  },
  // The src/app/*.ts feature fragments are split mid-construct and only parse
  // when concatenated, so they are type-checked as a bundle via
  // `npm run typecheck:standalone` rather than individually here.
  "include": ["js/auth.ts", "build.ts", "scripts/**/*.ts", "src/app/globals.d.ts"],
  "exclude": ["node_modules", "frontend", "backend", "dist"]
}
